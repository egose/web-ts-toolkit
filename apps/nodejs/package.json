{
  "name": "org-access-nodejs-example",
  "private": true,
  "scripts": {
    "build:deps": "pnpm --filter @web-ts-toolkit/access-router... build && pnpm --filter @web-ts-toolkit/message-service... build",
    "build": "pnpm run build:deps && tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@web-ts-toolkit/access-router": "workspace:*",
    "@web-ts-toolkit/express-runtime": "workspace:*",
    "@web-ts-toolkit/message-service": "workspace:*",
    "express": "^5.2.1",
    "mongodb-memory-server": "^11.1.0",
    "mongoose": "^9.6.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.20.6",
    "zod": "^4.1.12",
    "typescript": "^6.0.3"
  }
}
