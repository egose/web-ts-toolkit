{
  "name": "{{APP_NAME}}",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "preview": "vite preview",
    "test": "vitest",
    "server": "wtt-express-runtime dev ./api/app-dev.ts --env .env --require tsx --watch ./api --ext ts --port 8000",
    "server:once": "wtt-express-runtime dev ./api/app-dev.ts --env .env --require tsx --port 8000",
    "serverless": "wtt-express-runtime build ./api/app.ts --init ./api/init.ts --out-dir api/functions --out-name main --format cjs --target node22",
    "serverless:start": "wtt-express-runtime start ./api/functions/main.cjs --port 9000 --env .env"
  },
  "dependencies": {
    "@egose/shadcn-theme": "^0.1.10",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@web-ts-toolkit/access-router": "^0.6.1",
    "@web-ts-toolkit/access-router-client": "^0.6.1",
    "@web-ts-toolkit/access-router-react": "^0.6.1",
    "axios": "^1.16.1",
    "express": "^5.2.1",
    "mongoose": "^9.7.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-router": "^7.16.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/express": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.2",
    "@web-ts-toolkit/express-runtime": "^0.9.0",
    "eslint": "^10.4.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
