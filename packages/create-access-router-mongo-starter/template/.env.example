# Shared API route prefix for the backend, Vite dev proxy, and frontend client.
# Leave as /api for the default local setup.
API_BASE_URL=/api

# Optional frontend-only override. Leave unset unless the built frontend needs
# to target a different mount path than the backend default above.
# VITE_API_BASE_URL=/api

# Local backend port (defaults to 8000). Picked up by the `server` script.
PORT=8000

# MongoDB connection string. Required by `startDB()` for every runtime (local
# dev server, serverless bundle, tests if you add backend tests). Use any
# MongoDB instance: local, Atlas, or another hosted provider.
MONGODB_URI=mongodb://localhost:27017/{{DB_NAME}}
