  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "peerDependencies": {
    "@web-ts-toolkit/access-router": "workspace:*",
    "express": ">=5.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "@web-ts-toolkit/access-router": "workspace:*",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "typescript": "^6.0.3"
  }
}
