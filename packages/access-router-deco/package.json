{
  "name": "@web-ts-toolkit/access-router-deco",
  "description": "Decorator-based configuration for @web-ts-toolkit/access-router",
  "homepage": "https://web-ts-toolkit.pages.dev/docs/packages/access-router-deco",
  "version": "0.0.0-PLACEHOLDER",
  "license": "PLACEHOLDER",
  "repository": "PLACEHOLDER",
  "keywords": [
    "typescript",
    "express",
    "mongoose",
    "decorators",
    "acl",
    "access-router"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "pnpm --filter @web-ts-toolkit/access-router-deco... build && vitest run --config vitest.config.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
