{
  "name": "@web-ts-toolkit/access-router-react",
  "description": "React hooks for @web-ts-toolkit/access-router-client model services",
  "version": "0.0.0-PLACEHOLDER",
  "keywords": [
    "react",
    "hooks",
    "access-router",
    "model",
    "crud"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "pnpm --filter @web-ts-toolkit/access-router-react... build && vitest run --config vitest.config.ts"
  },
  "files": [
    "README.md",
    "dist",
    "tsup.config.ts"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@web-ts-toolkit/access-router-client": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@web-ts-toolkit/access-router-client": "workspace:*",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.21.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
