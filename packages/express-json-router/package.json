{
  "name": "@web-ts-toolkit/express-json-router",
  "description": "Express router wrapper for return-value JSON responses",
  "homepage": "https://web-ts-toolkit.pages.dev/docs/packages/express-json-router",
  "version": "0.0.0-PLACEHOLDER",
  "license": "Apache-2.0",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egose/web-ts-toolkit.git",
    "directory": "packages/express-json-router"
  },
  "keywords": [
    "express",
    "api",
    "json",
    "router",
    "http"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "pnpm --filter @web-ts-toolkit/express-json-router... build && vitest run --config ../../vitest.config.ts"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@web-ts-toolkit/express-response-handler": "workspace:*",
    "@web-ts-toolkit/http-errors": "workspace:*",
    "@web-ts-toolkit/utils": "workspace:*",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "supertest": "^7.2.2"
  }
}
