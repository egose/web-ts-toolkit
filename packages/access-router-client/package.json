{
  "name": "@web-ts-toolkit/access-router-client",
  "description": "Typed client utilities for @web-ts-toolkit/access-router APIs",
  "homepage": "https://web-ts-toolkit.pages.dev/docs/packages/access-router-client",
  "version": "0.0.0-PLACEHOLDER",
  "license": "PLACEHOLDER",
  "sideEffects": false,
  "repository": "PLACEHOLDER",
  "keywords": [
    "axios",
    "typescript",
    "api-client",
    "batching",
    "access-router"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "pnpm --filter @web-ts-toolkit/access-router-client... build && vitest run --config ../../vitest.config.ts"
  },
  "files": [
    "README.md",
    "llms.txt",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@web-ts-toolkit/utils": "workspace:*",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "@web-ts-toolkit/access-router": "workspace:*",
    "express": "^5.2.1",
    "mongodb-memory-server": "^11.1.0",
    "mongoose": "^9.6.2",
    "zod": "^4.1.12"
  }
}
