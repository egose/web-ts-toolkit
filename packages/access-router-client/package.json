{
  "name": "@web-ts-toolkit/access-router-client",
  "description": "Client adapter for interacting with @web-ts-toolkit/access-router APIs",
  "version": "0.0.0-PLACEHOLDER",
  "keywords": [
    "express",
    "mongoose",
    "adapter",
    "api",
    "client"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "pnpm --filter @web-ts-toolkit/access-router-client... build && vitest run --config ../../vitest.config.ts"
  },
  "files": [
    "README.md",
    "dist",
    "tsup.config.ts"
  ],
  "dependencies": {
    "@web-ts-toolkit/utils": "workspace:*",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "@web-ts-toolkit/access-router": "workspace:*",
    "express": "^5.2.1",
    "mongodb-memory-server": "^11.1.0",
    "mongoose": "^9.6.2",
    "zod": "^4.1.12"
  }
}
