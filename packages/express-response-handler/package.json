{
  "name": "@web-ts-toolkit/express-response-handler",
  "description": "FastAPI-style return-value response handling for Express",
  "homepage": "https://web-ts-toolkit.pages.dev/docs/packages/express-response-handler",
  "version": "0.0.0-PLACEHOLDER",
  "sideEffects": false,
  "keywords": [
    "express",
    "api",
    "responses",
    "http",
    "error-handling"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/public-types.d.ts",
      "import": "./dist/public-types.mjs",
      "require": "./dist/public-types.js",
      "default": "./dist/public-types.js"
    },
    "./responses": {
      "types": "./dist/responses/index.d.ts",
      "import": "./dist/responses/index.mjs",
      "require": "./dist/responses/index.js",
      "default": "./dist/responses/index.js"
    },
    "./responses/csv": {
      "types": "./dist/responses/csv.d.ts",
      "import": "./dist/responses/csv.mjs",
      "require": "./dist/responses/csv.js",
      "default": "./dist/responses/csv.js"
    },
    "./responses/success": {
      "types": "./dist/responses/success.d.ts",
      "import": "./dist/responses/success.mjs",
      "require": "./dist/responses/success.js",
      "default": "./dist/responses/success.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "pnpm --filter @web-ts-toolkit/express-response-handler... build && vitest run --config ../../vitest.config.ts"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fast-csv/format": "^5.0.5",
    "@web-ts-toolkit/http-errors": "workspace:*",
    "@web-ts-toolkit/utils": "workspace:*"
  },
  "devDependencies": {
    "@fast-csv/parse": "^5.0.5",
    "@types/node": "^25.6.0",
    "express": "^5.2.1",
    "supertest": "^7.2.2"
  }
}
